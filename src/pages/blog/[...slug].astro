---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.tsx';
import { Calendar, Tag, Folder, ArrowLeft, Clock } from 'lucide-react';
import readingTime from 'reading-time';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, heroImage, category, tags, music } = post.data;
const stats = readingTime(post.body || '');

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(pubDate);
---

<BaseLayout title={`${title} - AnimeBlog`} description={description}>
	{music && (
		<div 
			id="music-data" 
			data-music={JSON.stringify({ url: music, title: title })} 
			style="display: none;"
		></div>
	)}
	<article class="max-w-4xl mx-auto space-y-12">
		{/* Post Header */}
		<div class="space-y-8 text-center">
			<a
				href="/"
				class="inline-flex items-center gap-2 text-primary hover:translate-x-[-4px] transition-transform font-bold"
			>
				<ArrowLeft size={20} />
				<span>返回首页</span>
			</a>

			<div class="space-y-4">
				<div class="flex items-center justify-center gap-4 text-sm text-muted-foreground font-medium">
					<span class="flex items-center gap-1.5 bg-primary/10 text-primary px-3 py-1 rounded-full">
						<Folder size={14} />
						{category}
					</span>
					<span class="flex items-center gap-1.5">
						<Calendar size={14} />
						{formattedDate}
					</span>
					<span class="flex items-center gap-1.5">
						<Clock size={14} />
						{stats.text}
					</span>
				</div>
				<h1 class="text-4xl md:text-6xl font-black text-foreground leading-tight">
					{title}
				</h1>
			</div>

			<div class="flex flex-wrap justify-center gap-3">
				{tags.map((tag) => (
					<span class="flex items-center gap-1.5 text-sm bg-secondary/20 text-primary px-4 py-1.5 rounded-full font-bold border-2 border-primary/5 hover:border-primary/20 transition-all cursor-default">
						<Tag size={14} />
						{tag}
					</span>
				))}
			</div>
		</div>

		{/* Hero Image */}
		{heroImage && (
			<div class="cute-card !p-0 overflow-hidden relative group">
				<Image
					src={heroImage}
					alt={title}
					width={1200}
					height={675}
					format="webp"
					class="w-full aspect-video object-cover transition-transform duration-700 group-hover:scale-105"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none" />
			</div>
		)}

		{/* Content */}
		<div class="cute-card !p-8 md:!p-12 prose prose-pink prose-lg max-w-none dark:prose-invert">
			<Content />
		</div>

		{/* Footer Actions */}
		<ShareButtons client:load title={title} url={Astro.url.href} />
	</article>
</BaseLayout>

<style is:global>
	/* MDX Prose Styling Overrides for "Cute" feel */
	.prose h1, .prose h2, .prose h3, .prose h4 {
		color: var(--primary);
		font-weight: 900;
		margin-top: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.prose p {
		line-height: 2;
		margin-bottom: 1.5rem;
	}

	.prose blockquote {
		border-left: 6px solid var(--primary);
		background: rgba(255, 133, 161, 0.05);
		padding: 1.5rem 2rem;
		border-radius: 0 1.5rem 1.5rem 0;
		font-style: italic;
		font-weight: 500;
		color: var(--foreground);
	}

	.prose code {
		background: rgba(255, 133, 161, 0.1);
		color: var(--primary);
		padding: 0.2rem 0.5rem;
		border-radius: 0.5rem;
		font-weight: bold;
	}

	.prose pre {
		background: #2d2d2d;
		border-radius: 1.5rem;
		padding: 2rem;
		border: 2px solid var(--border);
		box-shadow: 0 8px 0 var(--border);
		margin: 2.5rem 0;
	}

	.prose img {
		border-radius: 1.5rem;
		border: 2px solid var(--border);
		box-shadow: 0 12px 0 var(--border);
		margin: 3rem auto;
	}

	.prose a {
		color: var(--primary);
		text-decoration: underline;
		text-decoration-style: wavy;
		text-underline-offset: 4px;
		font-weight: bold;
	}

	.prose a:hover {
		color: var(--primary-hover);
	}
</style>
